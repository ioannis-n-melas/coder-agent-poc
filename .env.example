# Copy to .env and fill in. .env is git-ignored.
# These are read by scripts/*.sh and by local dev docker-compose.

# ── GCP ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=coder-agent-poc-2026
GCP_REGION=europe-west4               # all services + AR (ADR-0014)
GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX  # gcloud billing accounts list

# ── Artifact Registry ────────────────────────────────────────────────
AR_REPO=coder-agent
AR_HOST=europe-west4-docker.pkg.dev    # both services pull from here

# ── Model (GPU / vLLM) ───────────────────────────────────────────────
# model-server is now vLLM + Qwen3-Coder-30B-A3B-Instruct AWQ (ADR-0010, ADR-0013).
# ml-engineer owns the Dockerfile; these vars are informational.
VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_MAX_MODEL_LEN=32768

# ── Service image tags ───────────────────────────────────────────────
MODEL_SERVER_IMAGE_TAG=v0.2.0
CODER_AGENT_IMAGE_TAG=v0.2.0

# ── Cloud Build (for model-server GPU image) ─────────────────────────
# Set USE_CLOUD_BUILD=true to build the model-server image via Cloud Build
# instead of local Docker. Strongly recommended for the large CUDA image
# (see build-and-push.sh header for cost/tradeoff details).
USE_CLOUD_BUILD=false
CLOUD_BUILD_REGION=europe-west4

# ── Cloud Run sizing ─────────────────────────────────────────────────
# model-server: GPU (L4) mandates 8 vCPU / 32 Gi.
MODEL_SERVER_CPU=8
MODEL_SERVER_MEMORY=32Gi
MODEL_SERVER_MIN_INSTANCES=0
MODEL_SERVER_MAX_INSTANCES=1
MODEL_SERVER_CONCURRENCY=1

CODER_AGENT_CPU=1
CODER_AGENT_MEMORY=1Gi
CODER_AGENT_MIN_INSTANCES=0
CODER_AGENT_MAX_INSTANCES=3
CODER_AGENT_CONCURRENCY=8

# ── Local dev ─────────────────────────────────────────────────────────
LOCAL_MODEL_SERVER_PORT=8080
LOCAL_CODER_AGENT_PORT=8000
